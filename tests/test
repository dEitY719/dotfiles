#!/bin/bash
#
# Test Suite Runner for Dotfiles Project
#
# Usage:
#   ./tests/test              # Run all tests (parallel by default)
#   ./tests/test -a|--all     # Run all tests (same as above)
#   ./tests/test -v|--verbose # Run with verbose output
#   ./tests/test -s|--serial  # Run tests sequentially (disable parallel)
#   ./tests/test -h|--help    # Show help
#
# Requirements:
#   - Python 3.10+
#   - pytest
#   - pytest-xdist (for parallel execution)
#   - pexpect
#
# Environment:
#   Sets DOTFILES_TEST_MODE=1 for test-aware tool behavior
#   Parallel execution uses all available CPU cores by default
#

# Note: Do NOT use 'set -e' as it terminates the script when main() returns
# non-zero exit code. Instead, we handle errors explicitly in main() function.

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

# Helper functions
print_header() {
    echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}! $1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

# Show help
show_help() {
    cat <<EOF
Test Suite Runner for Dotfiles Project

USAGE:
    ./tests/test [OPTIONS]

OPTIONS:
    -a, --all       Run all tests (default)
    -v, --verbose   Run with verbose output
    -s, --serial    Run tests sequentially (disable parallel execution)
    -h, --help      Show this help message

ENVIRONMENT VARIABLES:
    DOTFILES_TEST_MODE=1  Enable test mode (prevents side effects)

EXAMPLES:
    ./tests/test                  # Run all tests (parallel)
    ./tests/test --verbose        # Verbose output (parallel)
    ./tests/test --serial         # Sequential execution
    ./tests/test --verbose --serial # Verbose + sequential

PERFORMANCE:
    Default: bats + pytest both run parallel across all CPU cores (~4-5 min)
    Serial:  Sequential execution, single bats process (~15+ min)
    Tune:    BATS_JOBS=N overrides bats job count (default: nproc)

REQUIREMENTS:
    - Python 3.10+
    - pytest
    - pytest-xdist (for parallel execution)
    - pexpect

For more information, see: docs/abc-review-CX.md, docs/test-results-P0.md, and tests/README.md

EOF
}

# Check requirements
check_requirements() {
    local missing=0

    # Check Python
    if ! command -v python3 >/dev/null 2>&1; then
        print_error "Python 3 not found"
        missing=1
    else
        local py_version=$(python3 --version 2>&1 | awk '{print $2}')
        print_info "Python $py_version"
    fi

    # Check pytest
    if ! python3 -m pytest --version >/dev/null 2>&1; then
        print_error "pytest not found. Install with: pip install pytest pexpect"
        missing=1
    else
        local pytest_version=$(python3 -m pytest --version 2>&1 | head -1)
        print_info "$pytest_version"
    fi

    # Check pytest-xdist (optional, for parallel execution)
    # Use import check instead of pip show — uv-managed venvs may not have pip
    HAS_XDIST=0
    local xdist_version
    xdist_version=$(python3 -c "import xdist; print(xdist.__version__)" 2>/dev/null)
    if [ $? -eq 0 ]; then
        print_info "pytest-xdist $xdist_version (parallel execution enabled)"
        HAS_XDIST=1
    else
        print_warning "pytest-xdist not found. Tests will run serially. Install with: uv sync --group dev"
    fi

    if [ $missing -eq 1 ]; then
        print_error "Missing required dependencies"
        return 1
    fi

    return 0
}


# Run bats tests
#
# bats-core's own `--jobs` needs GNU parallel (or shenwei356/rush), which we
# do not want as a hard test dependency. Instead we run one bats process per
# .bats file bounded by CPU count via `xargs -P` — dependency-free and
# portable to bash 3.2 (macOS) + Linux. This is safe because every bats test
# isolates its own $HOME via mktemp (see tests/bats/test_helper.bash
# setup_isolated_home), so file-level parallelism has no shared mutable state.
# Serial mode (-s) keeps the single-process path for deterministic output.
run_bats() {
    local bats_bin="${SCRIPT_DIR}/bats/lib/bats-core/bin/bats"
    if [ ! -x "$bats_bin" ]; then
        print_warning "bats-core not found. Skipping shell unit tests."
        print_info "Run: git submodule update --init --recursive"
        return 0
    fi

    print_header "Running Bats Shell Unit Tests"

    # Discover .bats files (exclude lib/ submodules), ordered by @test count
    # descending (Longest-Processing-Time scheduling) so the long-pole file
    # starts first and the parallel makespan approaches its floor.
    local bats_files=()
    while IFS= read -r f; do
        bats_files+=("$f")
    done < <(
        find "${SCRIPT_DIR}/bats" -type f -name '*.bats' -not -path '*/lib/*' \
            -exec sh -c 'printf "%s\t%s\n" "$(grep -c "^@test" "$1")" "$1"' _ {} \; \
            | sort -rn | cut -f2-
    )
    if [ ${#bats_files[@]} -eq 0 ]; then
        print_warning "No bats test files found"
        return 0
    fi

    # Serial: single bats invocation over all files (deterministic order).
    if [ "$SERIAL" = "1" ]; then
        "$bats_bin" "${bats_files[@]}"
        return $?
    fi

    # Parallel: one bats process per file, bounded by CPU count.
    local jobs="${BATS_JOBS:-$(nproc 2>/dev/null || echo 4)}"
    local outdir
    outdir="$(mktemp -d)"
    print_info "Parallel: ${#bats_files[@]} files across ${jobs} jobs (override with BATS_JOBS=N, or -s for serial)"

    printf '%s\n' "${bats_files[@]}" \
        | xargs -P "$jobs" -I {} bash -c '
            f="$1"; bats="$2"; out="$3"
            base=$(printf "%s" "$f" | tr "/" "_")
            if "$bats" "$f" >"$out/$base.log" 2>&1; then
                printf "0" >"$out/$base.status"
            else
                printf "1" >"$out/$base.status"
            fi
          ' _ {} "$bats_bin" "$outdir"

    # Aggregate: count tests, print per-file failures with their full log.
    local rc=0 total_tests=0 failed_files=0
    local f base status_val log_file
    for f in "${bats_files[@]}"; do
        base=$(printf "%s" "$f" | tr '/' '_')
        log_file="$outdir/$base.log"
        status_val=$(cat "$outdir/$base.status" 2>/dev/null || echo 1)
        if [ -f "$log_file" ]; then
            local n
            n=$(grep -cE '^(ok|not ok)' "$log_file" 2>/dev/null || echo 0)
            total_tests=$((total_tests + n))
        fi
        if [ "$status_val" != "0" ]; then
            failed_files=$((failed_files + 1))
            rc=1
            print_error "FAILED: ${f#"${SCRIPT_DIR}/"}"
            [ -f "$log_file" ] && cat "$log_file"
        elif [ "$VERBOSE" = "1" ] && [ -f "$log_file" ]; then
            cat "$log_file"
        fi
    done

    rm -rf "$outdir"

    if [ "$rc" -eq 0 ]; then
        print_success "bats: ${total_tests} tests in ${#bats_files[@]} files passed"
    else
        print_error "bats: ${failed_files} of ${#bats_files[@]} files failed (${total_tests} tests total)"
    fi
    return $rc
}

# Run golden rules
run_golden_rules() {
    local gr_script="${SCRIPT_DIR}/golden_rules/test_golden_rules.sh"
    if [ -f "$gr_script" ]; then
        print_header "Running Golden Rules"
        bash "$gr_script"
        return $?
    fi
    return 0
}

# Run pytest integration tests
run_pytest() {
    local verbose_flag=""

    if [ "$VERBOSE" = "1" ]; then
        verbose_flag="-v"
    fi

    print_header "Running Pytest Integration Tests"
    if [ "$SERIAL" = "1" ] || [ "$HAS_XDIST" = "0" ]; then
        # Serial: override addopts to remove xdist options
        python3 -m pytest tests/integration/ \
            $verbose_flag \
            --tb=short \
            -o addopts="-v --strict-markers" \
            -p no:xdist
    else
        python3 -m pytest tests/integration/ $verbose_flag --tb=short
    fi
    return $?
}

# Run all tests
run_tests() {
    cd "$REPO_ROOT"
    export DOTFILES_TEST_MODE=1

    local exit_code=0

    run_bats || exit_code=1
    run_golden_rules || exit_code=1
    run_pytest || exit_code=1

    return $exit_code
}

# Main
main() {
    local VERBOSE=0
    local SERIAL=0

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
        -a | --all)
            shift
            ;;
        -v | --verbose)
            VERBOSE=1
            shift
            ;;
        -s | --serial)
            SERIAL=1
            shift
            ;;
        -h | --help)
            show_help
            return 0
            ;;
        *)
            print_error "Unknown option: $1"
            echo "Use -h or --help for usage information"
            return 1
            ;;
        esac
    done

    # Check requirements
    if ! check_requirements; then
        return 1
    fi

    # Run tests
    if run_tests; then
        print_success "All tests passed!"
        return 0
    else
        print_error "Some tests failed"
        return 1
    fi
}

# Run main function and exit with its return code
main "$@"
exit_code=$?
exit $exit_code
