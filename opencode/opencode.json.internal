{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": false,
    "model": "litellm/GLM4.7",
    "small_model": "litellm/GLM4.7",
    "provider": {
        "litellm": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "LiteLLM Provider (DTGPT)",
            "options": {
                "baseURL": "http://cloud.dtgpt.samsungds.net/llm/v1",
                "apiKey": "${DTGPT_API_KEY}"
            },
            "models": {
                "Kimi-K2.5": {
                    "name": "Kimi-K2.5"
                },
                "MiniMax-M2.1": {
                    "name": "MiniMax-M2.1"
                },
                "GLM4.7": {
                    "name": "GLM4.7"
                }
            }
        }
    },
    "plugin": [
        "opencode-notify"
    ]
}
