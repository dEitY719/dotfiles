#!/bin/sh
# proxy.local.sh (template)
# 환경별 프록시 설정 예제 (회사 환경용)
#
# 사용 방법:
#   1. 이 파일을 proxy.local.sh로 복사
#      cp proxy.local.example proxy.local.sh
#   2. 필요에 따라 프록시 설정 수정
#   3. proxy.local.sh는 자동으로 .gitignore에 의해 제외됨

# 회사 프록시 설정
export http_proxy="http://12.26.204.100:8080/"
export HTTP_PROXY="$http_proxy"
export https_proxy="http://12.26.204.100:8080/"
export HTTPS_PROXY="$https_proxy"

# Ref. https://confluence.samsungds.net/pages/viewpage.action?pageId=1367083095
# FYI. NO_PROXY 값 사이에 공백이 있으면 제대로 인식되지 않을 수 있으니, 콤마(,)로만 구분 추천
export no_proxy="10.229.95.200,10.229.95.220,12.36.155.91,12.36.154.116,12.36.154.130,localhost,127.0.0.1,.samsung.net,.samsungds.net,ssai.samsungds.net,dsvdi.net,pfs.nprotect.com"
export NO_PROXY="$no_proxy"

# ============================================================
# NOTE: proxy_help() 및 check-proxy 명령어는 proxy.sh에서
#       환경 구분 없이 모든 환경에서 사용 가능합니다.
#       이 파일은 환경별 프록시 설정 오버라이드만 포함합니다.
# ============================================================
