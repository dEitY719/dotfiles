# security.local.sh (template)
# 환경별 보안 설정 예제 (CA 인증서 관리)
#
# 사용 방법:
#   1. 이 파일을 security.local.sh로 복사
#      cp security.local.example security.local.sh
#   2. 환경에 맞는 CA 설정 선택 (아래 옵션 중 하나)
#   3. security.local.sh는 자동으로 로드됨 (.gitignore에 의해 제외됨)


# WARNING: Choose CA certificate path (enable only ONE option)
# Option 1: Corporate external PC (VPN) - installed by setup_crt.sh2
# 인증서 파일은 아래 링크에서 Download
# http://12.53.3.52:5465/apc/AgentInstall/list_agent.htm
CA_CERT="/usr/local/share/ca-certificates/samsungsemi-prx.com.crt"

# Option 2: Corporate internal PC (direct connection) - system CA bundle
#CA_CERT="/etc/ssl/certs/ca-certificates.crt"


# CA certificate setup (Node.js, Python)
# Only set if file exists to maintain compatibility with home environments
if [ -f "$CA_CERT" ]; then
    export NODE_EXTRA_CA_CERTS="$CA_CERT"
    export REQUESTS_CA_BUNDLE="$CA_CERT"
fi

# ========================================
# SSL Certificate Configuration for curl, wget, and other tools
# ========================================
# Used by: curl, wget, git, and other command-line tools
# Option 1: Corporate external PC - Custom certificate
#SSL_CERT_FILE="/usr/local/share/ca-certificates/samsungsemi-prx.com.crt"

# Option 2: Corporate internal PC - McAfee proxy certificate
SSL_CERT_FILE="/usr/share/ca-certificates/extra/McAfee_Certificate.crt"

# Export only if file exists
if [ -f "$SSL_CERT_FILE" ]; then
    export SSL_CERT_FILE
fi

# ========================================
# Notes
# ========================================
# - Corporate external PC: Use option 1 after installing certificate with setup_crt.sh
# - Corporate internal PC: Use option 2 (McAfee Certificate - default)
#   - NODE_EXTRA_CA_CERTS + REQUESTS_CA_BUNDLE: uses system CA bundle
#   - SSL_CERT_FILE: uses McAfee proxy certificate for curl, wget, git
# - Home environment: Do not create security.local.sh (CA setup not needed)
