#!/bin/sh
# npm.local.sh (template)
# 환경별 NPM 설정 예제 (회사 환경용)
#
# 사용 방법:
#   1. 이 파일을 npm.local.sh로 복사
#      cp npm.local.example npm.local.sh
#   2. 필요에 따라 설정 수정
#   3. npm.local.sh는 자동으로 .gitignore에 의해 제외됨
#
# NVM의 방식을 따르는 스크립트 (NVM 로드 + 프록시 설정)
#
# 참고:
#   - CA 인증서(NODE_EXTRA_CA_CERTS) 설정은 shell-common/env/security.local.sh에서 관리됩니다
#   - NPM PATH 설정(~/.npm-global/bin)은 npm.sh의 PATH export로 관리됩니다
#   - npm의 prefix 설정은 이 스크립트에서 ~/.npm-global으로 명시적 설정합니다

# --- 1. NVM 로드 ---
export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    # nvm 스크립트를 로드합니다
    \. "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

    # NVM 로드 후: .npmrc에서 prefix 설정을 제거하여 충돌 방지
    # NVM은 자체적으로 npm을 관리하므로 prefix 설정이 있으면 경고를 출력합니다
    if [ -f "$HOME/.npmrc" ] && grep -q "^prefix=" "$HOME/.npmrc" 2>/dev/null; then
        sed -i '/^prefix=/d' "$HOME/.npmrc"
        # 빈 파일이 되면 삭제
        if [ ! -s "$HOME/.npmrc" ]; then
            rm -f "$HOME/.npmrc"
        fi
    fi
fi

# --- 2. .npmrc 설정 (레지스트리, CA, 프록시 등) ---
# nvm 로드가 완료되어 'npm' 명령어를 사용할 수 있을 때
if command -v npm >/dev/null 2>&1; then

    # ========================================
    # === Option1: 외부 npmjs + 회사 CA (권장, 기본값) ===
    # 환경: 회사 외부PC (VPN 또는 직접 연결)
    # 특징: 프록시 불필요 (직접 인터넷 접근)
    # ========================================
    DESIRED_REGISTRY="https://registry.npmjs.org/"
    DESIRED_CAFILE="/usr/local/share/ca-certificates/samsungsemi-prx.com.crt"
    DESIRED_STRICT_SSL="true"
    DESIRED_PROXY=""
    DESIRED_HTTPS_PROXY=""
    DESIRED_NOPROXY=""

    # ========================================
    # === Option2: 내부 Artifactory + 회사 프록시 (필요시 주석 변경) ===
    # 환경: 회사 내부PC (직접 연결, 프록시 필수)
    # 특징: 회사 내부만 접근 + 프록시 필수
    # ========================================
    # DESIRED_REGISTRY="http://repo.samsungds.net:8081/artifactory/api/npm/npm/"
    # DESIRED_CAFILE="/etc/ssl/certs/ca-certificates.crt"
    # DESIRED_STRICT_SSL="false"
    # DESIRED_PROXY="http://12.26.204.100:8080"
    # DESIRED_HTTPS_PROXY="http://12.26.204.100:8080"
    # DESIRED_NOPROXY="10.229.95.200,10.229.95.220,12.36.155.91,12.36.154.116,12.36.154.130,localhost,127.0.0.1,.samsung.net,.samsungds.net,dsvdi.net,pfs.nprotect.com"

    # ========================================
    # === 공통 설정 (환경별 상관없음) ===
    # ========================================
    DESIRED_PREFIX="$HOME/.npm-global"

    # --- 현재 값과 비교하여 다를 경우에만 설정 실행 ---

    # 1. registry
    CURRENT_REGISTRY="$(npm config get registry 2>/dev/null)"
    if [[ "$CURRENT_REGISTRY" != "$DESIRED_REGISTRY" ]]; then
        npm config set registry "$DESIRED_REGISTRY"
    fi

    # 2. cafile
    CURRENT_CAFILE="$(npm config get cafile 2>/dev/null)"
    if [[ "$CURRENT_CAFILE" != "$DESIRED_CAFILE" ]]; then
        npm config set cafile "$DESIRED_CAFILE"
    fi

    # 3. strict-ssl
    CURRENT_STRICT_SSL="$(npm config get strict-ssl 2>/dev/null)"
    if [[ "$CURRENT_STRICT_SSL" != "$DESIRED_STRICT_SSL" ]]; then
        npm config set strict-ssl "$DESIRED_STRICT_SSL"
    fi

    # 4. proxy
    CURRENT_PROXY="$(npm config get proxy 2>/dev/null)"
    if [[ "$CURRENT_PROXY" != "$DESIRED_PROXY" ]]; then
        npm config set proxy "$DESIRED_PROXY"
    fi

    # 5. https-proxy
    CURRENT_HTTPS_PROXY="$(npm config get https-proxy 2>/dev/null)"
    if [[ "$CURRENT_HTTPS_PROXY" != "$DESIRED_HTTPS_PROXY" ]]; then
        npm config set https-proxy "$DESIRED_HTTPS_PROXY"
    fi

    # 6. noproxy
    CURRENT_NOPROXY="$(npm config get noproxy 2>/dev/null)"
    if [[ "$CURRENT_NOPROXY" != "$DESIRED_NOPROXY" ]]; then
        npm config set noproxy "$DESIRED_NOPROXY"
    fi

    # 7. prefix (사용자 전역 폴더)
    CURRENT_PREFIX="$(npm config get prefix 2>/dev/null)"
    if [[ "$CURRENT_PREFIX" != "$DESIRED_PREFIX" ]]; then
        npm config set prefix "$DESIRED_PREFIX"
    fi
fi