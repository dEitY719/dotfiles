{
  "env": {
    "GH_PR_REPLY_AUTO_APPROVE_REPOS": "dEitY719/dotfiles"
  },
  "permissions": {
    "allow": [
      "Edit(**/test_*.py)",
      "Edit(**/*_test.py)",
      "Edit(**/tests/**/*.py)",
      "ReadFile(**/test_*.py)",
      "ReadFile(**/*_test.py)",
      "ReadFile(**/tests/**/*.py)",
      "ReadFile(.env)",
      "ReadFile(**/.env)",
      "ReadFile(.env.*)",
      "ReadFile(**/.env.*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(mypy:*)",
      "Bash(tox:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)"
    ],
    "deny": [
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(**/credentials.json)",
      "Read(**/*secret*)",
      "Edit(~/.bashrc)",
      "Edit(~/.bash_profile)",
      "Edit(/etc/**)",
      "Bash(rm -rf:*)",
      "Bash(sudo rm:*)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "model": "haiku",
  "statusLine": {
    "type": "command",
    "command": "${HOME}/dotfiles/claude/statusline-command.sh"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/dotfiles/claude/hooks/gh_issue_flow_stop_guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/dotfiles/claude/hooks/post-gh-pr-create.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker"
    ]
  },
  "telemetry": {
    "enabled": false
  }
}
