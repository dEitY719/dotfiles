#!/bin/bash
#
# Test Suite Runner for Dotfiles Project
#
# Usage:
#   ./scripts/test              # Run all tests
#   ./scripts/test -a|--all     # Run all tests (same as above)
#   ./scripts/test -v|--verbose # Run with verbose output
#   ./scripts/test -h|--help    # Show help
#
# Requirements:
#   - Python 3.10+
#   - pytest
#   - pexpect
#
# Environment:
#   Sets DOTFILES_TEST_MODE=1 for test-aware tool behavior
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

# Helper functions
print_header() {
    echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}! $1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

# Show help
show_help() {
    cat <<EOF
Test Suite Runner for Dotfiles Project

USAGE:
    ./scripts/test [OPTIONS]

OPTIONS:
    -a, --all       Run all tests (default)
    -v, --verbose   Run with verbose output
    -h, --help      Show this help message

ENVIRONMENT VARIABLES:
    DOTFILES_TEST_MODE=1  Enable test mode (prevents side effects)

EXAMPLES:
    ./scripts/test                  # Run all tests
    ./scripts/test --verbose        # Verbose output
    ./scripts/test -a | head -50    # Show first 50 lines

REQUIREMENTS:
    - Python 3.10+
    - pytest
    - pexpect

For more information, see: docs/abc-review-C.md

EOF
}

# Check requirements
check_requirements() {
    local missing=0

    # Check Python
    if ! command -v python3 >/dev/null 2>&1; then
        print_error "Python 3 not found"
        missing=1
    else
        local py_version=$(python3 --version 2>&1 | awk '{print $2}')
        print_info "Python $py_version"
    fi

    # Check pytest
    if ! python3 -m pytest --version >/dev/null 2>&1; then
        print_error "pytest not found. Install with: pip install pytest pexpect"
        missing=1
    else
        local pytest_version=$(python3 -m pytest --version 2>&1 | head -1)
        print_info "$pytest_version"
    fi

    if [ $missing -eq 1 ]; then
        print_error "Missing required dependencies"
        return 1
    fi

    return 0
}

# Run tests
run_tests() {
    local verbose_flag=""
    if [ "$VERBOSE" = "1" ]; then
        verbose_flag="-v"
    fi

    cd "$REPO_ROOT"
    export DOTFILES_TEST_MODE=1

    print_header "Running Test Suite"
    python3 -m pytest tests/ $verbose_flag --tb=short
    return $?
}

# Main
main() {
    local VERBOSE=0

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
        -a | --all)
            shift
            ;;
        -v | --verbose)
            VERBOSE=1
            shift
            ;;
        -h | --help)
            show_help
            exit 0
            ;;
        *)
            print_error "Unknown option: $1"
            echo "Use -h or --help for usage information"
            exit 1
            ;;
        esac
    done

    # Check requirements
    if ! check_requirements; then
        exit 1
    fi

    # Run tests
    if run_tests; then
        print_success "All tests passed!"
        exit 0
    else
        print_error "Some tests failed"
        exit 1
    fi
}

# Run main function
main "$@"
