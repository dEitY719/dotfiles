.idea
.venv
*egg-info
*.pyc

.python-version
uv.lock

.git-credentials
git/.git-credentials
**/.git-credentials

.temp/
# Local machine-specific configurations
*.local.sh
ssh/*.local
shell-common/config/pg_services.list
# AWS Bedrock host-specific override for ~/.aws/config (#677 F-6).
# *.local.sh already covers aws/aws.local.sh; aws-config.local has no .sh
# extension so it needs an explicit rule.
aws/aws-config.local
# Note: pip.conf is symlinked to ~/.config/pip/pip.conf (outside this repo, not version controlled)

# Build artifacts (generated during setup in some environments)
build/
__pycache__/
*.egg-info/

# Secrets — never track. Originals must live outside the repo
# (e.g., ~/.config/dotfiles-secrets/ or a password manager).
.env
.secrets/
.git-crypt/

# Claude Code settings.json is now the tracked SSOT (#584). Only timestamped
# backups produced by setup.sh symlink-replacement remain ignored.
claude/settings.json.backup.*
# settings.local.json carries PC-specific env (사내 ANTHROPIC_BASE_URL,
# ANTHROPIC_AUTH_TOKEN, 사번 헤더 등). Gitignored so secrets never reach
# GitHub. Internal-PC users hand-create ~/.claude/settings.local.json once;
# claude/setup.sh prints the exact heredoc on Internal mode (#584).
claude/settings.local.json
.claude/

# Claude Code plugin manifest — 사내 전용 분류는 별도 private nested repo로
# 관리한다 (docs/feature/superpowers-specs/2026-07-01-claude-plugin-manifest-design.md).
# public 레포는 이 경로의 존재 자체를 추적하지 않는다.
/claude/plugin/company/

# VS Code settings (bidirectional sync system, PC-specific)
.vscode/settings.json
.vscode/base.json.backup.*

# AGENTS.md generator backups
**/AGENTS.md.backup.*

# Oh-My-Zsh plugin installations (managed by install scripts)
# Users run install-* commands which clone plugins to ~/.oh-my-zsh/custom/plugins/
# These should NOT be tracked in dotfiles repo (environment-specific)
~/.oh-my-zsh/
.oh-my-zsh/
