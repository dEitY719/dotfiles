.idea
.venv
*egg-info
*.pyc

.python-version
uv.lock

.git-credentials
git/.git-credentials
**/.git-credentials

# Local machine-specific configurations
*.local.sh
ssh/*.local
shell-common/config/pg_services.list
# Note: pip.conf is symlinked to ~/.config/pip/pip.conf (outside this repo, not version controlled)

# Build artifacts (generated during setup in some environments)
build/
__pycache__/
*.egg-info/

.secrets/*.asc

# Claude Code personal settings (user-specific, environment-dependent)
claude/settings.json

# VS Code settings (bidirectional sync system, PC-specific)
.vscode/settings.json
.vscode/base.json.backup.*

# AGENTS.md generator backups
**/AGENTS.md.backup.*

# Oh-My-Zsh plugin installations (managed by install scripts)
# Users run install-* commands which clone plugins to ~/.oh-my-zsh/custom/plugins/
# These should NOT be tracked in dotfiles repo (environment-specific)
~/.oh-my-zsh/
.oh-my-zsh/
