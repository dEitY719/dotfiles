.idea
.venv
*egg-info
*.pyc

.python-version
uv.lock

.git-credentials
git/.git-credentials
**/.git-credentials

# Local machine-specific configurations
*.local.sh
ssh/*.local
shell-common/config/pg_services.list
# Note: pip.conf is symlinked to ~/.config/pip/pip.conf (outside this repo, not version controlled)

# Build artifacts (generated during setup in some environments)
build/
__pycache__/
*.egg-info/

.secrets/*.asc

# Claude Code personal settings (user-specific, environment-dependent)
claude/settings.json
# Migration backups carry the same secrets as the source — keep them out of
# the tree even when the migration helper happens to write here (issue #554).
claude/settings.json.*
# settings.local.json carries PC-specific env (사내 ANTHROPIC_BASE_URL, 사번
# 헤더 등). Tracked-by-mistake history: 0b36f07 committed it as an "SSOT
# 통합", but that path leaks secrets the moment an internal-PC user pastes
# the Samsung gateway env block in. Treat it like .env — gitignored,
# bootstrapped from settings.local.example.json on first setup (issue #571).
claude/settings.local.json
.claude/

# VS Code settings (bidirectional sync system, PC-specific)
.vscode/settings.json
.vscode/base.json.backup.*

# AGENTS.md generator backups
**/AGENTS.md.backup.*

# Oh-My-Zsh plugin installations (managed by install scripts)
# Users run install-* commands which clone plugins to ~/.oh-my-zsh/custom/plugins/
# These should NOT be tracked in dotfiles repo (environment-specific)
~/.oh-my-zsh/
.oh-my-zsh/
