#!/usr/bin/env bash
# Global Git Pre-commit Wrapper
#
# This script is configured via 'git config --global core.hooksPath'
# It runs on EVERY commit in ANY repository this user touches.
#
# Logic:
# 1. Global Safety Checks (Secrets, Conflicts, Debug, Size, Email, Tox)
# 2. Project-Specific Hook Delegation (.githooks, git/hooks, .git/hooks)
#
# To bypass: git commit --no-verify

set -u

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Get Repo Root
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$REPO_ROOT" ]; then
    exit 0
fi

# Get Staged Files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo -e "${BLUE}[Global Hook] Running safety checks...${NC}"

# ═══════════════════════════════════════════════════════════════════════════
# 1. Global Safety Checks
# ═══════════════════════════════════════════════════════════════════════════

EXIT_CODE=0
CHECKS_FAILED=0

# A. Secret/Key Blocking
# ----------------------
# Look for private keys and generic API tokens
FORBIDDEN_KEYS="-----BEGIN OPENSSH PRIVATE KEY-----|-----BEGIN RSA PRIVATE KEY-----|AKIA[0-9A-Z]{16}"
if echo "$STAGED_FILES" | xargs grep -E "$FORBIDDEN_KEYS" >/dev/null 2>&1; then
    echo -e "${RED}❌ BLOCKING: Potential secret/key detected in staged files!${NC}"
    echo "$STAGED_FILES" | xargs grep -E -l "$FORBIDDEN_KEYS" | sed 's/^/   - /'
    CHECKS_FAILED=1
fi

# B. Conflict Marker Check
# ------------------------
if echo "$STAGED_FILES" | xargs grep -lE "^<<<<<<< |^>>>>>>> " >/dev/null 2>&1; then
    echo -e "${RED}❌ BLOCKING: Git conflict markers left in code!${NC}"
    echo "$STAGED_FILES" | xargs grep -lE "^<<<<<<< |^>>>>>>> " | sed 's/^/   - /'
    CHECKS_FAILED=1
fi

# C. Debug Code Blocking
# ----------------------
# Common debug patterns: pdb, binding.pry, console.log (stricter)
# Exclude some file types if necessary
DEBUG_PATTERNS="pdb\.set_trace\(\)|binding\.pry|console\.log\("
# Only check text files
if echo "$STAGED_FILES" | grep -vE "\.md$|\.txt$|\.json$" | xargs grep -E "$DEBUG_PATTERNS" >/dev/null 2>&1; then
    echo -e "${RED}❌ BLOCKING: Debug code detected (remove before commit)!${NC}"
    echo "$STAGED_FILES" | grep -vE "\.md$|\.txt$|\.json$" | xargs grep -E -l "$DEBUG_PATTERNS" | sed 's/^/   - /'
    CHECKS_FAILED=1
fi

# D. Large File Warning (>10MB)
# -----------------------------
# 10MB = 10485760 bytes
LARGE_FILES=$(echo "$STAGED_FILES" | xargs -I {} find "{}" -type f -size +10M 2>/dev/null)
if [ -n "$LARGE_FILES" ]; then
    echo -e "${RED}❌ BLOCKING: Attempting to commit files larger than 10MB!${NC}"
    echo "$LARGE_FILES" | sed 's/^/   - /'
    echo "   (Use Git LFS or .gitignore for large binaries)"
    CHECKS_FAILED=1
fi

# E. Email Identity Check (Warning)
# ---------------------------------
USER_EMAIL=$(git config user.email)
CURRENT_DIR=$(pwd)

# Heuristic: "work" dir vs "gmail", "personal" dir vs "corp"
if [[ "$CURRENT_DIR" == *"work"* || "$CURRENT_DIR" == *"corp"* ]]; then
    if [[ "$USER_EMAIL" == *"gmail.com"* || "$USER_EMAIL" == *"naver.com"* ]]; then
        echo -e "${YELLOW}⚠️  WARNING: Committing to WORK directory with PERSONAL email ($USER_EMAIL)${NC}"
        # This is just a warning, doesn't set CHECKS_FAILED
    fi
elif [[ "$CURRENT_DIR" == *"personal"* || "$CURRENT_DIR" == *"dotfiles"* ]]; then
    # Assuming standard corp emails don't look like these public providers
    if [[ "$USER_EMAIL" != *"gmail.com"* && "$USER_EMAIL" != *"naver.com"* && "$USER_EMAIL" != *"outlook.com"* ]]; then
        echo -e "${YELLOW}⚠️  WARNING: Committing to PERSONAL directory with (likely) WORK email ($USER_EMAIL)${NC}"
    fi
fi

# F. Tox Check (Project-Aware Global Check)
# -----------------------------------------
if [ -f "$REPO_ROOT/tox.ini" ]; then
    # Only run if tox is installed
    if command -v tox &> /dev/null; then
        echo -e "${BLUE}   running tox checks (ruff, shfmt, shellcheck)...${NC}"
        
        # Run silently first
        if ! tox -e ruff,shfmt,shellcheck > /dev/null 2>&1; then
             echo -e "${RED}❌ BLOCKING: tox checks failed!${NC}"
             echo "   Re-running to show errors:"
             # Re-run to show output
             tox -e ruff,shfmt,shellcheck
             CHECKS_FAILED=1
        else
             echo -e "${GREEN}   ✓ Tox checks passed.${NC}"
        fi
    else
        # Warn but don't fail if tox is missing? Or Fail? 
        # User requested "Must perform and check for errors". 
        # If tox.ini is present, implying a tox project, having tox installed is a reasonable requirement.
        echo -e "${RED}❌ BLOCKING: tox.ini exists but 'tox' command is missing.${NC}"
        echo "   Please install tox to commit in this repository."
        CHECKS_FAILED=1
    fi
fi

# Summary Exit
if [ $CHECKS_FAILED -ne 0 ]; then
    echo -e "${RED}Commit blocked by Global Safety Checks.${NC}"
    exit 1
fi

# ═══════════════════════════════════════════════════════════════════════════
# 2. Delegation to Local Hooks
# ═══════════════════════════════════════════════════════════════════════════

# Candidate hooks in priority order
CANDIDATE_HOOKS=(
  ".githooks/pre-commit"       # Team shared hook
  "git/hooks/pre-commit"       # Dotfiles/Custom structure
  ".git/hooks/pre-commit"      # Standard/Local hook (e.g. Husky)
)

RUN_HOOK=""

for hook in "${CANDIDATE_HOOKS[@]}"; do
    if [ -x "$REPO_ROOT/$hook" ]; then
        # Avoid self-execution loop check
        RUN_HOOK="$REPO_ROOT/$hook"
        break
    fi
done

if [ -n "$RUN_HOOK" ]; then
    echo -e "${BLUE}[Global Hook] Delegating to project hook: $RUN_HOOK${NC}"
    "$RUN_HOOK" "$@"
    exit $?
fi

exit 0