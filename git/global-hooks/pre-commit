#!/usr/bin/env bash
# Global Git Pre-commit Wrapper
#
# This script is configured via 'git config --global core.hooksPath'
# It runs on EVERY commit in ANY repository this user touches.
#
# Logic:
# 1. Global Safety Checks (Lightweight, Fast, Universal)
#    - Secrets/Keys Detection
#    - Conflict Markers
#    - Trailing Whitespace
#    - Large Files (>10MB)
#    - Email Identity Warning
# 2. Project-Specific Hook Delegation (.githooks, git/hooks, .git/hooks)
#
# To bypass: git commit --no-verify
# To skip global checks: export GIT_HOOKS_SKIP_GLOBAL=1
# To debug: export GIT_HOOKS_DEBUG=1

set -u

# ═══════════════════════════════════════════════════════════════════════════
# Helper Functions
# ═══════════════════════════════════════════════════════════════════════════

# Portable realpath function (macOS compatible)
get_realpath() {
    local path="$1"

    # Try realpath command first (if available)
    if command -v realpath >/dev/null 2>&1; then
        realpath "$path" 2>/dev/null && return 0
    fi

    # Try readlink -f (GNU coreutils)
    if readlink -f "$path" 2>/dev/null; then
        return 0
    fi

    # Fallback: manual resolution
    if [ -L "$path" ]; then
        # It's a symlink
        local link_target
        link_target=$(readlink "$path" 2>/dev/null || echo "$path")
        if [ "${link_target:0:1}" = "/" ]; then
            # Absolute path
            echo "$link_target"
        else
            # Relative path - suppress cd errors internally
            local dir
            dir=$(dirname "$path")
            echo "$(cd "$dir" 2>/dev/null && pwd -P)/$(basename "$link_target")" || echo "$path"
        fi
    elif [ -e "$path" ]; then
        # Regular file/directory
        if [ -d "$path" ]; then
            echo "$(cd "$path" 2>/dev/null && pwd -P)" || echo "$path"
        else
            local dir
            dir=$(dirname "$path")
            echo "$(cd "$dir" 2>/dev/null && pwd -P)/$(basename "$path")" || echo "$path"
        fi
    else
        # Doesn't exist
        echo "$path"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════
# Load SSOT Hook Config (optional)
# ═══════════════════════════════════════════════════════════════════════════

# Attempt to source dotfiles hook config when this hook is installed as a symlink
# to the dotfiles repo (recommended). If the config can't be found, fall back to
# script-local defaults so this hook still works in all repositories.
SCRIPT_REALPATH=$(get_realpath "$0")
SCRIPT_DIR=$(dirname "$SCRIPT_REALPATH")
HOOK_CONFIG_PATH="$SCRIPT_DIR/../config/hook-config.sh"

if [ -f "$HOOK_CONFIG_PATH" ]; then
    # shellcheck source=/dev/null
    . "$HOOK_CONFIG_PATH"
fi

# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURATION: Forbidden Filenames (P0 Security - SSOT)
# ═══════════════════════════════════════════════════════════════════════════

# Patterns that should NEVER be committed (single source of truth)
# Structured approach: basename rules, path rules, env rules with allowlist

# Basename that should almost never be committed (file credentials/keys only)
FORBIDDEN_BASENAME_ERE="${GIT_HOOKS_FORBIDDEN_BASENAME_ERE:-^(\.git-credentials|credentials\.json|private\.key|secret\.key|id_rsa|id_dsa|id_ed25519|.*\.pem)$}"

# Env files: blocked by default, but allow example/sample/template/dist
ENV_BASENAME_BLOCK_ERE="${GIT_HOOKS_ENV_BASENAME_BLOCK_ERE:-^\.env(\..*)?$}"
ENV_BASENAME_ALLOW_ERE="${GIT_HOOKS_ENV_BASENAME_ALLOW_ERE:-^\.env\.([^.]+\.)?(example|sample|template|dist)$}"

# Path-based sensitive locations (repo-relative, including directories)
FORBIDDEN_PATH_ERE="${GIT_HOOKS_FORBIDDEN_PATH_ERE:-(^|/)\.aws/(credentials|config)$}"

# ═══════════════════════════════════════════════════════════════════════════
# FUNCTION: Check if a staged path contains forbidden filename/pattern
# ═══════════════════════════════════════════════════════════════════════════
# Returns 0 if forbidden, 1 if allowed
# Separates basename checks from path checks for precision and maintainability
is_forbidden_staged_path() {
    local path="$1"
    local base="${path##*/}"  # Extract basename (everything after last /)

    # 1. Check path-based rules first (most specific: .aws/credentials, etc.)
    if printf '%s\n' "$path" | grep -Eq "$FORBIDDEN_PATH_ERE"; then
        return 0
    fi

    # 2. Check basename-based forbidden files (credentials.json, id_rsa, etc.)
    if printf '%s\n' "$base" | grep -Eq "$FORBIDDEN_BASENAME_ERE"; then
        return 0
    fi

    # 3. Check env files with allowlist
    # Default: .env* is blocked, but allow .env.example, .env.sample, .env.template, .env.dist
    if printf '%s\n' "$base" | grep -Eq "$ENV_BASENAME_BLOCK_ERE"; then
        # If it matches the allow pattern, it's safe
        if printf '%s\n' "$base" | grep -Eq "$ENV_BASENAME_ALLOW_ERE"; then
            return 1
        fi
        # Otherwise it's forbidden
        return 0
    fi

    # 4. All other files are allowed
    return 1
}

# ═══════════════════════════════════════════════════════════════════════════
# Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# Skip global checks if requested (emergency use)
if [ "${GIT_HOOKS_SKIP_GLOBAL:-0}" = "1" ]; then
    echo "[Global Hook] Skipping global checks (GIT_HOOKS_SKIP_GLOBAL=1)"
    # Still delegate to project hook
    SKIP_GLOBAL=1
else
    SKIP_GLOBAL=0
fi

# Debug mode
DEBUG=${GIT_HOOKS_DEBUG:-0}

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Get Repo Root
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$REPO_ROOT" ]; then
    [ "$DEBUG" = "1" ] && echo "[Debug] Not in a git repository, exiting"
    exit 0
fi

# Check if there are any staged files (NUL-safe streaming check)
# Use a temporary counter since bash variables cannot preserve NUL bytes
if ! git diff --cached --name-only -z --diff-filter=ACMR 2>/dev/null | grep -q .; then
    [ "$DEBUG" = "1" ] && echo "[Debug] No staged files, exiting"
    exit 0
fi

# Count staged files for debug (using streaming approach)
STAGED_COUNT=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | wc -l)
[ "$DEBUG" = "1" ] && echo "[Debug] Found $STAGED_COUNT staged file(s)"

# ═══════════════════════════════════════════════════════════════════════════
# 1. Global Safety Checks (Lightweight Only!)
# ═══════════════════════════════════════════════════════════════════════════

if [ "$SKIP_GLOBAL" = "0" ]; then
    echo -e "${BLUE}[Global Hook] Running safety checks...${NC}"

    CHECKS_FAILED=0
    WARNINGS=0

    # ───────────────────────────────────────────────────────────────────────
    # A. Secret/Key Blocking (CRITICAL)
    # ───────────────────────────────────────────────────────────────────────
    [ "$DEBUG" = "1" ] && echo "[Debug] Checking for secrets/keys..."

    # Look for private keys and generic API tokens
    FORBIDDEN_KEYS="${GIT_HOOKS_FORBIDDEN_KEYS_ERE:------BEGIN OPENSSH PRIVATE KEY-----|-----BEGIN RSA PRIVATE KEY-----|-----BEGIN PRIVATE KEY-----|AKIA[0-9A-Z]{16}}"

    # Use git grep --cached to check index content (NUL-safe)
    # -I: ignore binary files
    # -E: extended regex
    # --cached: search index, not working tree
    if git grep --cached -I -lE "$FORBIDDEN_KEYS" 2>/dev/null | head -1 | grep -q .; then
        echo -e "${RED}❌ BLOCKING: Potential secret/key detected in staged files!${NC}"
        git grep --cached -I -lE "$FORBIDDEN_KEYS" 2>/dev/null | sed 's/^/   - /'
        echo "   Hint: Check for private keys, AWS keys (AKIA...), etc."
        CHECKS_FAILED=1
    fi

    # ───────────────────────────────────────────────────────────────────────
    # B. Conflict Marker Check (CRITICAL)
    # ───────────────────────────────────────────────────────────────────────
    [ "$DEBUG" = "1" ] && echo "[Debug] Checking for conflict markers..."

    # Check for conflict markers in staged content
    #
    # IMPORTANT: Keep this regex strict to avoid false positives.
    # - "=======" conflict separator is exactly 7 '=' (optionally with whitespace)
    # - Exclude documentation files; docs may intentionally show conflict marker examples
    CONFLICT_MARKERS_REGEX="${GIT_HOOKS_CONFLICT_MARKERS_ERE:-^(<<<<<<<([[:space:]]|$)|=======[[:space:]]*$|>>>>>>>([[:space:]]|$))}"
    CONFLICT_MARKER_MATCHES=$(git grep --cached -I -lE "$CONFLICT_MARKERS_REGEX" -- \
        ':!*.md' ':!*.txt' ':!*.rst' ':!*.adoc' 2>/dev/null || true)

    if [ -n "$CONFLICT_MARKER_MATCHES" ]; then
        echo -e "${RED}❌ BLOCKING: Git conflict markers left in code!${NC}"
        echo "$CONFLICT_MARKER_MATCHES" | sed 's/^/   - /'
        echo "   Hint: Resolve merge conflicts before committing"
        CHECKS_FAILED=1
    fi

    # ───────────────────────────────────────────────────────────────────────
    # A-B. Forbidden Filename Check (CRITICAL - P0) [NUL-SAFE STREAMING]
    # Using function-based check for modularity and testability
    # Include rename (R) to catch sensitive files moved into repo
    # ───────────────────────────────────────────────────────────────────────
    [ "$DEBUG" = "1" ] && echo "[Debug] Checking for forbidden filenames..."

    FORBIDDEN_FILES=""
    while IFS= read -r -d '' file; do
        [ -z "$file" ] && continue
        if is_forbidden_staged_path "$file"; then
            FORBIDDEN_FILES="${FORBIDDEN_FILES}${file}"$'\n'
        fi
    done < <(git diff --cached --name-only -z --diff-filter=ACMR 2>/dev/null || true)

    if [ -n "$FORBIDDEN_FILES" ]; then
        echo -e "${RED}❌ BLOCKING: Forbidden filename(s) detected - likely contains secrets!${NC}"
        echo "$FORBIDDEN_FILES" | sed 's/^/   - /'
        echo ""
        echo "   This file should NOT be committed. Likely contains:"
        echo "   - Credentials (.git-credentials, credentials.json)"
        echo "   - Private keys (id_rsa, id_dsa, id_ed25519, *.pem, secret.key)"
        echo "   - Environment variables (.env, .env.local, .env.dev)"
        echo "   - AWS credentials (.aws/credentials, .aws/config)"
        echo ""
        echo "   Template files ALLOWED: .env.example, .env.sample, .env.template, .env.dist"
        echo ""
        echo "   Action required:"
        echo "   1. git rm --cached <file>"
        echo "   2. Add to .gitignore: echo '<pattern>' >> .gitignore"
        echo "   3. If already pushed: ROTATE your credentials immediately"
        CHECKS_FAILED=1
    fi

    # ───────────────────────────────────────────────────────────────────────
    # C. Trailing Whitespace Check (STANDARD)
    # ───────────────────────────────────────────────────────────────────────
    [ "$DEBUG" = "1" ] && echo "[Debug] Checking for trailing whitespace..."

    # Use git's built-in check (very fast) and cache result
    WHITESPACE_CHECK_OUTPUT=$(git diff --cached --check 2>&1)
    WHITESPACE_CHECK_EXIT=$?

    if [ $WHITESPACE_CHECK_EXIT -ne 0 ]; then
        echo -e "${RED}❌ BLOCKING: Trailing whitespace detected!${NC}"
        echo "$WHITESPACE_CHECK_OUTPUT" | head -20 | sed 's/^/   /'
        WHITESPACE_LINE_COUNT=$(echo "$WHITESPACE_CHECK_OUTPUT" | wc -l)
        [ "$WHITESPACE_LINE_COUNT" -gt 20 ] && echo "   ... and more"
        CHECKS_FAILED=1
    fi

    # ───────────────────────────────────────────────────────────────────────
    # D. Debug Code Detection (CONSERVATIVE)
    # ───────────────────────────────────────────────────────────────────────
    [ "$DEBUG" = "1" ] && echo "[Debug] Checking for debug code..."

    # Only check for EXPLICIT debug statements (not console.log)
    # pdb: Python debugger
    # binding.pry: Ruby debugger
    # debugger;: JavaScript debugger keyword
    # breakpoint(): Python 3.7+ debugger
    DEBUG_PATTERNS="${GIT_HOOKS_DEBUG_PATTERNS_ERE:-pdb\\.set_trace\\(\\)|binding\\.pry|^[[:space:]]*debugger;|breakpoint\\(\\)}"

    # Use git grep --cached, exclude documentation and shell scripts.
    # Note: This hook contains comments like "breakpoint()" which would otherwise self-match.
    if declare -p GIT_HOOKS_DEBUG_GREP_EXCLUDES >/dev/null 2>&1; then
        DEBUG_MATCHES=$(git grep --cached -I -lE "$DEBUG_PATTERNS" -- "${GIT_HOOKS_DEBUG_GREP_EXCLUDES[@]}" 2>/dev/null || true)
    else
        DEBUG_MATCHES=$(git grep --cached -I -lE "$DEBUG_PATTERNS" -- ':!*.md' ':!*.txt' ':!*.json' ':!*.yaml' ':!*.yml' ':!*.sh' 2>/dev/null || true)
    fi

    if [ -n "$DEBUG_MATCHES" ]; then
        echo -e "${YELLOW}⚠️  WARNING: Debug code detected (consider removing):${NC}"
        echo "$DEBUG_MATCHES" | sed 's/^/   - /'
        WARNINGS=1
        # Don't block - just warn
    fi

    # ───────────────────────────────────────────────────────────────────────
    # E. Large File Warning (>10MB) [NUL-SAFE STREAMING]
    # ───────────────────────────────────────────────────────────────────────
    [ "$DEBUG" = "1" ] && echo "[Debug] Checking for large files..."

    # Check index blob sizes (more accurate than working tree)
    # Use NUL-safe streaming: git diff -z outputs NUL-separated filenames
    # read -d '' reads until NUL byte
    LARGE_FILES=""
    while IFS= read -r -d '' file; do
        [ -z "$file" ] && continue

        # Get blob size from index
        BLOB_SIZE=$(git cat-file -s ":$file" 2>/dev/null || echo "0")

        # 10MB default (SSOT override via hook-config.sh)
        LARGE_THRESHOLD_BYTES="${GIT_HOOKS_LARGE_FILE_BYTES:-10485760}"
        if [ "$BLOB_SIZE" -gt "$LARGE_THRESHOLD_BYTES" ]; then
            LARGE_FILES="${LARGE_FILES}${file} ($(($BLOB_SIZE / 1048576))MB)"$'\n'
        fi
    done < <(git diff --cached --name-only -z --diff-filter=ACMR 2>/dev/null)

    if [ -n "$LARGE_FILES" ]; then
        echo -e "${RED}❌ BLOCKING: Attempting to commit files larger than 10MB!${NC}"
        echo "$LARGE_FILES" | sed 's/^/   - /'
        echo "   Hint: Use Git LFS or add to .gitignore for large binaries"
        CHECKS_FAILED=1
    fi

    # ───────────────────────────────────────────────────────────────────────
    # F. Email Identity Check (WARNING ONLY)
    # ───────────────────────────────────────────────────────────────────────
    [ "$DEBUG" = "1" ] && echo "[Debug] Checking email identity..."

    USER_EMAIL=$(git config user.email)
    CURRENT_DIR=$(pwd)

    # Heuristic: Check directory path vs email domain
    if [[ "$CURRENT_DIR" == *"/work/"* || "$CURRENT_DIR" == *"/corp/"* ]]; then
        if [[ "$USER_EMAIL" == *"gmail.com"* || "$USER_EMAIL" == *"naver.com"* || "$USER_EMAIL" == *"outlook.com"* ]]; then
            echo -e "${YELLOW}⚠️  WARNING: Committing to WORK directory with PERSONAL email${NC}"
            echo "   Current: $USER_EMAIL"
            echo "   Path: $CURRENT_DIR"
            WARNINGS=1
        fi
    elif [[ "$CURRENT_DIR" == *"/personal/"* || "$CURRENT_DIR" == *"/home/"* ]]; then
        # Check if email looks corporate (not common providers)
        if [[ "$USER_EMAIL" != *"gmail.com"* && "$USER_EMAIL" != *"naver.com"* && "$USER_EMAIL" != *"outlook.com"* && "$USER_EMAIL" != *"hotmail.com"* && "$USER_EMAIL" != *"yahoo.com"* ]]; then
            echo -e "${YELLOW}⚠️  WARNING: Committing to PERSONAL directory with (likely) WORK email${NC}"
            echo "   Current: $USER_EMAIL"
            echo "   Path: $CURRENT_DIR"
            WARNINGS=1
        fi
    fi

    # ───────────────────────────────────────────────────────────────────────
    # Summary of Global Checks
    # ───────────────────────────────────────────────────────────────────────

    if [ $CHECKS_FAILED -ne 0 ]; then
        echo ""
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}Commit BLOCKED by global safety checks${NC}"
        echo -e "${RED}Fix the issues above or use 'git commit --no-verify' to bypass${NC}"
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        exit 1
    elif [ $WARNINGS -ne 0 ]; then
        echo -e "${GREEN}✓ Global checks passed (with warnings above)${NC}"
    else
        echo -e "${GREEN}✓ All global checks passed${NC}"
    fi
fi

# ═══════════════════════════════════════════════════════════════════════════
# 2. Delegation to Project-Specific Hooks
# ═══════════════════════════════════════════════════════════════════════════

[ "$DEBUG" = "1" ] && echo "[Debug] Searching for project-level hooks..."

# Candidate hooks in priority order
CANDIDATE_HOOKS=(
  ".githooks/pre-commit"       # Team shared hook (highest priority)
  "git/hooks/pre-commit"       # Dotfiles/Custom structure
  ".git/hooks/pre-commit"      # Standard/Local hook (e.g. Husky)
)

RUN_HOOK=""
CURRENT_SCRIPT=$(get_realpath "$0")

for hook in "${CANDIDATE_HOOKS[@]}"; do
    HOOK_PATH="$REPO_ROOT/$hook"

    [ "$DEBUG" = "1" ] && echo "[Debug] Checking: $HOOK_PATH"

    if [ -x "$HOOK_PATH" ]; then
        # Prevent self-execution loop
        HOOK_REALPATH=$(get_realpath "$HOOK_PATH")

        if [ "$HOOK_REALPATH" = "$CURRENT_SCRIPT" ]; then
            [ "$DEBUG" = "1" ] && echo "[Debug] Skipping self: $HOOK_PATH"
            continue
        fi

        RUN_HOOK="$HOOK_PATH"
        [ "$DEBUG" = "1" ] && echo "[Debug] Found executable hook: $RUN_HOOK"
        break
    fi
done

if [ -n "$RUN_HOOK" ]; then
    echo -e "${BLUE}[Global Hook] Delegating to project hook: $RUN_HOOK${NC}"
    echo ""

    # Execute project hook and propagate exit code
    if "$RUN_HOOK" "$@"; then
        echo ""
        echo -e "${GREEN}✓ Project hook completed successfully${NC}"
        exit 0
    else
        PROJECT_EXIT=$?
        echo ""
        echo -e "${RED}✗ Project hook failed with exit code $PROJECT_EXIT${NC}"
        exit $PROJECT_EXIT
    fi
else
    [ "$DEBUG" = "1" ] && echo "[Debug] No project-level hook found"
    echo -e "${BLUE}[Global Hook] No project-specific hook found, skipping delegation${NC}"
fi

exit 0
