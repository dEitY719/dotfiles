[credential]
	helper = store
[core]
	editor = code --wait
[pull]
	rebase = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[lfs]
	activitytimeout = 300
	locksverify = false
