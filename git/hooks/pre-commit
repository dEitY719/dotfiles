#!/usr/bin/env bash
# git/hooks/pre-commit
# Project-level pre-commit hook for dotfiles repo.
#
# Runner responsibilities:
# - Collect staged files
# - Dispatch checks
# - Aggregate results and exit appropriately
#
# Check implementations live in: git/hooks/checks/

# ═══════════════════════════════════════════════════════════════════════════
# Configuration and setup
# ═══════════════════════════════════════════════════════════════════════════

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
CHECKS_DIR="${HOOK_DIR}/checks"
REPO_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"

if [ ! -d "$CHECKS_DIR" ]; then
    echo -e "${RED}✗ BLOCKING: Checks directory not found: $CHECKS_DIR${NC}"
    exit 1
fi

# Create temporary files for error collection
TMPDIR="${TMPDIR:-/tmp}"
VIOLATIONS_FILE=$(mktemp "$TMPDIR/violations_XXXXXX.txt")
FUNC_VIOLATIONS_FILE=$(mktemp "$TMPDIR/func_violations_XXXXXX.txt")
SHEBANG_VIOLATIONS_FILE=$(mktemp "$TMPDIR/shebang_violations_XXXXXX.txt")
SUBSHELL_VIOLATIONS_FILE=$(mktemp "$TMPDIR/subshell_violations_XXXXXX.txt")
ALIAS_CONFLICT_FILE=$(mktemp "$TMPDIR/alias_conflict_XXXXXX.txt")
WRAPPER_VIOLATIONS_FILE=$(mktemp "$TMPDIR/wrapper_violations_XXXXXX.txt")
CUSTOM_TOOLS_SOURCING_FILE=$(mktemp "$TMPDIR/custom_tools_sourcing_XXXXXX.txt")
AUTO_EXEC_CUSTOM_FILE=$(mktemp "$TMPDIR/auto_exec_custom_XXXXXX.txt")
PURITY_VIOLATIONS_FILE=$(mktemp "$TMPDIR/purity_violations_XXXXXX.txt")

trap 'rm -f "$VIOLATIONS_FILE" "$FUNC_VIOLATIONS_FILE" "$SHEBANG_VIOLATIONS_FILE" "$SUBSHELL_VIOLATIONS_FILE" "$ALIAS_CONFLICT_FILE" "$WRAPPER_VIOLATIONS_FILE" "$CUSTOM_TOOLS_SOURCING_FILE" "$AUTO_EXEC_CUSTOM_FILE" "$PURITY_VIOLATIONS_FILE"' EXIT

# ═══════════════════════════════════════════════════════════════════════════
# Load check modules
# ═══════════════════════════════════════════════════════════════════════════

source_check_or_exit() {
    local path="$1"
    # shellcheck source=/dev/null
    if ! . "$path"; then
        echo -e "${RED}✗ BLOCKING: Failed to load hook module: $path${NC}"
        exit 1
    fi
}

source_check_or_exit "${CHECKS_DIR}/shared.sh"
source_check_or_exit "${CHECKS_DIR}/shebang_check.sh"
source_check_or_exit "${CHECKS_DIR}/naming_check.sh"
source_check_or_exit "${CHECKS_DIR}/ux_usage_check.sh"
source_check_or_exit "${CHECKS_DIR}/subshell_sourcing_check.sh"
source_check_or_exit "${CHECKS_DIR}/alias_conflict_check.sh"
source_check_or_exit "${CHECKS_DIR}/wrapper_check.sh"
source_check_or_exit "${CHECKS_DIR}/postmortem_init_check.sh"
source_check_or_exit "${CHECKS_DIR}/custom_tools_entrypoint_check.sh"
source_check_or_exit "${CHECKS_DIR}/library_purity_check.sh"

# ═══════════════════════════════════════════════════════════════════════════
# Get staged files (git diff --cached)
# ═══════════════════════════════════════════════════════════════════════════

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || echo "")
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# ═══════════════════════════════════════════════════════════════════════════
# Run checks
# ═══════════════════════════════════════════════════════════════════════════

shebang_violations=0
naming_violations=0
function_naming_violations=0
ux_violations=0
subshell_violations=0
alias_conflict_violations=0
wrapper_violations=0
custom_tools_sourcing_violations=0
auto_exec_custom_violations=0
library_purity_violations=0

# 1) Shebang consistency for staged .sh files under shell-common/bash/zsh
while IFS= read -r file; do
    [[ "$file" != *.sh ]] && continue
    [[ "$file" == shell-common/* ]] || [[ "$file" == bash/* ]] || [[ "$file" == zsh/* ]] || continue

    abs_path="$REPO_ROOT/$file"
    [ -f "$abs_path" ] || continue

    if ! check_shebang_violation "$REPO_ROOT" "$abs_path"; then
        expected=$(get_expected_shebang "$REPO_ROOT" "$abs_path")
        actual=$(head -n1 "$abs_path")
        echo "$file:1: Expected: $expected Got: $actual" >>"$SHEBANG_VIOLATIONS_FILE"
        ((shebang_violations++))
    fi
done <<<"$STAGED_FILES"

# 2) Unified checks for function files & integration tools
while IFS= read -r file; do
    [[ "$file" != shell-common/functions/*.sh && "$file" != shell-common/tools/integrations/*.sh ]] && continue
    [[ "$file" == *NAMING_CONVENTION* ]] && continue

    abs_path="$REPO_ROOT/$file"
    [ -f "$abs_path" ] || continue

    if [[ "$file" == shell-common/functions/*.sh ]]; then
        if ! check_naming_violations "$abs_path" "$VIOLATIONS_FILE" 2>/dev/null; then
            ((naming_violations++))
        fi

        if ! check_function_naming "$abs_path" "$FUNC_VIOLATIONS_FILE" 2>/dev/null; then
            ((function_naming_violations++))
        fi

        if ! check_ux_library_usage "$abs_path" 2>/dev/null; then
            ((ux_violations++))
        fi
    fi

    if ! check_subshell_sourcing "$abs_path" "$SUBSHELL_VIOLATIONS_FILE" 2>/dev/null; then
        ((subshell_violations++))
    fi

    if ! check_alias_function_conflict "$abs_path" "$ALIAS_CONFLICT_FILE" 2>/dev/null; then
        ((alias_conflict_violations++))
    fi

    if ! check_wrapper_function "$abs_path" "$WRAPPER_VIOLATIONS_FILE" 2>/dev/null; then
        ((wrapper_violations++))
    fi

    if ! check_library_purity "$REPO_ROOT" "$TMPDIR" "$file" "$PURITY_VIOLATIONS_FILE" 2>/dev/null; then
        ((library_purity_violations++))
    fi
done <<<"$STAGED_FILES"

# 3) Postmortem guardrails: init files
while IFS= read -r file; do
    if ! check_init_auto_sourcing "$REPO_ROOT" "$TMPDIR" "$file" "$CUSTOM_TOOLS_SOURCING_FILE" 2>/dev/null; then
        ((custom_tools_sourcing_violations++))
    fi
done <<<"$STAGED_FILES"

# 4) Postmortem guardrails: tools/custom scripts
while IFS= read -r file; do
    if ! check_auto_executable_in_custom "$REPO_ROOT" "$TMPDIR" "$file" "$AUTO_EXEC_CUSTOM_FILE" 2>/dev/null; then
        ((auto_exec_custom_violations++))
    fi
done <<<"$STAGED_FILES"

# ═══════════════════════════════════════════════════════════════════════════
# Reporting and exit logic
# ═══════════════════════════════════════════════════════════════════════════

echo ""
echo -e "${BLUE}Pre-commit validation (staged files only)${NC}"
echo ""

blocking_violations=$((shebang_violations + naming_violations + function_naming_violations + alias_conflict_violations + custom_tools_sourcing_violations + auto_exec_custom_violations + library_purity_violations))
warning_count=$((subshell_violations + wrapper_violations + ux_violations))

if [ $blocking_violations -eq 0 ]; then
    has_warnings=0

    if [ $subshell_violations -gt 0 ] && [ -s "$SUBSHELL_VIOLATIONS_FILE" ]; then
        echo -e "${YELLOW}⚠ [WARNING] Subshell sourcing anti-pattern ($subshell_violations violation(s)):${NC}"
        head -n 3 "$SUBSHELL_VIOLATIONS_FILE" | sed 's/^/  /'
        [ $(wc -l <"$SUBSHELL_VIOLATIONS_FILE") -gt 3 ] && echo "  ... and more" && echo ""
        echo ""
        has_warnings=1
    fi

    if [ $wrapper_violations -gt 0 ] && [ -s "$WRAPPER_VIOLATIONS_FILE" ]; then
        echo -e "${YELLOW}⚠ [WARNING] Wrapper function anti-patterns ($wrapper_violations violation(s)):${NC}"
        head -n 3 "$WRAPPER_VIOLATIONS_FILE" | sed 's/^/  /'
        [ $(wc -l <"$WRAPPER_VIOLATIONS_FILE") -gt 3 ] && echo "  ... and more" && echo ""
        echo ""
        has_warnings=1
    fi

    if [ $ux_violations -gt 0 ]; then
        echo -e "${YELLOW}⚠ [INFO] UX Library suggestions ($ux_violations file(s)):${NC}"
        echo "  Consider using UX functions for consistent output styling"
        echo ""
        has_warnings=1
    fi

    if [ $has_warnings -eq 0 ]; then
        echo -e "${GREEN}✓ All checks passed!${NC}"
    else
        echo -e "${GREEN}✓ All critical checks passed (with warnings above)${NC}"
    fi
    echo ""
    exit 0
fi

echo -e "${RED}✗ Found $blocking_violations BLOCKING violation(s)${NC}"
echo ""

if [ $custom_tools_sourcing_violations -gt 0 ] && [ -s "$CUSTOM_TOOLS_SOURCING_FILE" ]; then
    echo -e "${RED}[BLOCKING] tools/custom auto-sourcing in init files ($custom_tools_sourcing_violations):${NC}"
    cat "$CUSTOM_TOOLS_SOURCING_FILE" | sed 's/^/  /'
    echo ""
fi

if [ $auto_exec_custom_violations -gt 0 ] && [ -s "$AUTO_EXEC_CUSTOM_FILE" ]; then
    echo -e "${RED}[BLOCKING] Auto-executable tools/custom scripts without guard ($auto_exec_custom_violations):${NC}"
    cat "$AUTO_EXEC_CUSTOM_FILE" | sed 's/^/  /'
    echo ""
fi

if [ $library_purity_violations -gt 0 ] && [ -s "$PURITY_VIOLATIONS_FILE" ]; then
    echo -e "${RED}[BLOCKING] Library purity violations ($library_purity_violations):${NC}"
    cat "$PURITY_VIOLATIONS_FILE" | sed 's/^/  /'
    echo ""
fi

if [ $alias_conflict_violations -gt 0 ] && [ -s "$ALIAS_CONFLICT_FILE" ]; then
    echo -e "${RED}[BLOCKING] Alias/Function name conflicts ($alias_conflict_violations):${NC}"
    cat "$ALIAS_CONFLICT_FILE" | sed 's/^/  /'
    echo ""
fi

if [ $shebang_violations -gt 0 ] && [ -s "$SHEBANG_VIOLATIONS_FILE" ]; then
    echo -e "${RED}[BLOCKING] Shebang violations ($shebang_violations):${NC}"
    cat "$SHEBANG_VIOLATIONS_FILE" | sed 's/^/  /'
    echo ""
fi

if [ $naming_violations -gt 0 ] && [ -s "$VIOLATIONS_FILE" ]; then
    echo -e "${RED}[BLOCKING] Naming convention violations ($naming_violations):${NC}"
    echo "  User-facing text must use dash-form, not snake_case:"
    tail -n 5 "$VIOLATIONS_FILE" | sed 's/^/  /'
    echo ""
fi

if [ $function_naming_violations -gt 0 ] && [ -s "$FUNC_VIOLATIONS_FILE" ]; then
    echo -e "${RED}[BLOCKING] Function naming violations ($function_naming_violations):${NC}"
    echo "  Function definitions must use snake_case only:"
    tail -n 5 "$FUNC_VIOLATIONS_FILE" | sed 's/^/  /'
    echo ""
fi

# Show warnings too
if [ $subshell_violations -gt 0 ] && [ -s "$SUBSHELL_VIOLATIONS_FILE" ]; then
    echo -e "${YELLOW}[WARNING] Subshell sourcing anti-pattern ($subshell_violations):${NC}"
    head -n 2 "$SUBSHELL_VIOLATIONS_FILE" | sed 's/^/  /'
    echo ""
fi

if [ $wrapper_violations -gt 0 ] && [ -s "$WRAPPER_VIOLATIONS_FILE" ]; then
    echo -e "${YELLOW}[WARNING] Wrapper function anti-patterns ($wrapper_violations):${NC}"
    head -n 2 "$WRAPPER_VIOLATIONS_FILE" | sed 's/^/  /'
    echo ""
fi

exit 1
