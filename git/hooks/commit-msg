#!/bin/bash
# Git commit-msg hook: Validate Conventional Commits format
# Mode: WARNING-FIRST (shows errors but allows commits)
# To enable strict mode: COMMIT_MSG_STRICT=1 git commit
# Installed: git config core.hooksPath git/hooks

set -o errexit
set -o pipefail

# Get hook directory and import validator
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "${HOOK_DIR}/../lib/commit-msg-validator.sh" || exit 0

# ============================================
# MAIN HOOK LOGIC
# ============================================

# Get commit message file (first argument passed by git)
COMMIT_MSG_FILE="$1"

# Safety: If file doesn't exist or can't read, allow commit (prevent blocking)
if [ -z "$COMMIT_MSG_FILE" ] || [ ! -f "$COMMIT_MSG_FILE" ]; then
    exit 0
fi

# Read commit message (with error handling)
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE" 2>/dev/null | grep -v '^#' | tr -d '\0') || exit 0

# Trim whitespace
COMMIT_MSG="$(echo "$COMMIT_MSG" | sed -e 's/^[[:space:]]*//g' -e 's/[[:space:]]*$//g')"

# Skip if message is empty (might be merge commit)
if [ -z "$COMMIT_MSG" ]; then
    exit 0
fi

# Validate message
VALIDATION_RESULT=$(validate_commit_message "$COMMIT_MSG" 2>&1) || true

if [ -n "$VALIDATION_RESULT" ]; then
    echo ""
    echo "⚠️  Commit message issues detected:"
    echo "─────────────────────────────────────────────"
    echo "$VALIDATION_RESULT"
    echo "─────────────────────────────────────────────"
    echo ""
    echo "📝 Conventional Commits format:"
    echo "   <type>(<scope>): <subject>"
    echo ""
    echo "   Types: feat, fix, docs, style, refactor, perf, test, chore"
    echo "   Scope: (optional) affected component"
    echo "   Subject: concise description (< 50 chars)"
    echo ""
    echo "   Example:"
    echo "   feat(auth): add JWT token refresh mechanism"
    echo ""

    # Check strict mode
    if [ "${COMMIT_MSG_STRICT:-0}" = "1" ]; then
        echo "🚫 STRICT MODE ENABLED: Commit rejected"
        echo "   To override: COMMIT_MSG_STRICT=0 git commit"
        exit 1
    else
        echo "✅ WARNING-FIRST MODE: Commit allowed"
        echo "   Tip: Run 'COMMIT_MSG_STRICT=1 git commit' for strict validation"
        exit 0
    fi
fi

exit 0
