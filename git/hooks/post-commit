#!/bin/bash
# Post-commit hook: Automatic work log recording
# Records JIRA key and time spent to dotfiles-managed work_log.txt
# Path: dotfiles/work/log/work_log.txt (symlinked to ~/work_log.txt)

# Get git repo root directory to locate work_log.txt
GIT_ROOT="$(git rev-parse --show-toplevel)"
WORK_LOG_FILE="${GIT_ROOT}/work/log/work_log.txt"

# Fallback to ~/work_log.txt if not in dotfiles structure
if [ ! -f "$WORK_LOG_FILE" ]; then
    WORK_LOG_FILE="${HOME}/work_log.txt"
fi

# Get commit message
MSG=$(git log -1 --pretty=%B)

# Extract JIRA key - support multiple patterns (case-insensitive)
# Patterns: [SWINNOTEAM-906], [PROJ-245], [SWINNO-943], etc.
JIRA=$(echo "$MSG" | grep -io '\[[A-Z][A-Z0-9]*-[0-9]*\]' | head -1)

# If no match, try alternative patterns
if [ -z "$JIRA" ]; then
    JIRA=$(echo "$MSG" | grep -o '\[.*-[0-9]*\]' | head -1)
fi

# Extract TimeSpent from metadata (e.g., TimeSpent: 4.5h)
TIME=$(echo "$MSG" | grep "TimeSpent:" | sed 's/.*TimeSpent:\s*//;s/h.*/h/' | head -1)

# Extract Category
CATEGORY=$(echo "$MSG" | grep "Category:" | sed 's/.*Category:\s*//;s/[^A-Za-z].*//' | head -1)

# Get commit short hash
HASH=$(git log -1 --pretty=%h)

# Get branch name
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Get timestamp
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

# Create log entry if JIRA key exists
if [ -n "$JIRA" ]; then
    LOG_ENTRY="[$TIMESTAMP] $JIRA | $BRANCH | $TIME | $HASH"

    # Append to work log (create if doesn't exist)
    echo "$LOG_ENTRY" >> "$WORK_LOG_FILE" 2>/dev/null

    # Also log category if present
    if [ -n "$CATEGORY" ]; then
        echo "  └─ Category: $CATEGORY" >> "$WORK_LOG_FILE" 2>/dev/null
    fi
fi

exit 0
