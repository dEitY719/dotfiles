#!/bin/bash
# Post-commit hook: 작업 로그 자동 기록 (make-jira/make-confluence 호환)

# Git 메시지 파싱
MSG=$(git log -1 --pretty=%B)
HASH=$(git log -1 --pretty=format:%h)
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

# type(scope): description 에서 파싱
TYPE=$(echo "$MSG" | head -1 | grep -oE '^[a-z]+' || echo "main")
SCOPE=$(echo "$MSG" | head -1 | grep -oE '\([^)]+\)' | tr -d '()' || echo "")
SUBJECT=$(echo "$MSG" | head -1)

# TimeSpent 파싱 (정규화: "2h", "30m" → "2" or "0.5")
TIME=$(echo "$MSG" | grep -iE '^TimeSpent:' | cut -d: -f2 | xargs)
if [ -z "$TIME" ]; then
    TIME="-"
else
    # "2h" → "2", "30m" → "0.5"
    if [[ "$TIME" =~ m$ ]]; then
        TIME=$(echo "scale=1; ${TIME%m} / 60" | bc)
    else
        TIME="${TIME%h}"
    fi
fi

# Category 파싱
CATEGORY=$(echo "$MSG" | grep -iE '^Category:' | cut -d: -f2 | xargs)
if [ -z "$CATEGORY" ]; then
    CATEGORY="other"
fi

# Jira Key 파싱 (커밋 메시지에서 [KEY-123] 추출, 없으면 환경변수 사용)
JIRA_KEY=$(echo "$MSG" | grep -oE '\[[A-Z]+[A-Z0-9]*-[0-9]+\]' | head -1 | tr -d '[]' || echo "$JIRA_KEY")
if [ -z "$JIRA_KEY" ]; then
    JIRA_KEY="${JIRA_KEY_DEFAULT:-DOTFILES-AUTO}"
fi

# work_log.txt에 기록 (make-jira 호환 형식)
# work_log.txt는 ~/para/archive/playbook/logs/work_log.txt로 symlink되어 있음
# 활성화: DOTFILES_WORKLOG_ENABLED=1 (기본값: 비활성)
if [ "${DOTFILES_WORKLOG_ENABLED:-0}" = "1" ]; then
    LOGFILE="${HOME}/work_log.txt"
    if [ "$TIME" = "-" ]; then
        echo "[$TIMESTAMP] [$JIRA_KEY] | $TYPE | $CATEGORY | - | $HASH | $SUBJECT" >> "$LOGFILE"
    else
        echo "[$TIMESTAMP] [$JIRA_KEY] | $TYPE | $CATEGORY | ${TIME}h | $HASH | $SUBJECT" >> "$LOGFILE"
    fi
fi

# 메타정보 (선택사항)
# echo "  └─ Category: $CATEGORY" >> "$LOGFILE"

# ═══════════════════════════════════════════════════════════════════════════
# Playbook 자동 커밋
# 활성화: DOTFILES_WORKLOG_PLAYBOOK_AUTOCOMMIT=1 (기본값: 비활성)
# ═══════════════════════════════════════════════════════════════════════════

PLAYBOOK_DIR="${HOME}/para/archive/playbook"

# Playbook 저장소가 있는지 확인
if [ "${DOTFILES_WORKLOG_PLAYBOOK_AUTOCOMMIT:-0}" = "1" ] && [ -d "$PLAYBOOK_DIR/.git" ]; then
    cd "$PLAYBOOK_DIR" || exit 1

    # work_log.txt가 변경되었는지 확인
    if git diff-index --quiet HEAD -- logs/work_log.txt; then
        # 변경 없음
        :
    else
        # 변경이 있으면 자동 커밋
        git add logs/work_log.txt 2>/dev/null
        git commit -m "chore(work-log): $HASH $SUBJECT" 2>/dev/null || true
    fi

    cd - >/dev/null 2>&1 || true
fi
