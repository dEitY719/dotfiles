#!/bin/bash
# Post-commit hook: 작업 로그 자동 기록

# Git 메시지 파싱
MSG=$(git log -1 --pretty=%B)
HASH=$(git log -1 --pretty=format:%h)
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

# type(scope): description 에서 파싱
TYPE=$(echo "$MSG" | head -1 | grep -oE '^[a-z]+' || echo "unknown")
SCOPE=$(echo "$MSG" | head -1 | grep -oE '\([^)]+\)' | tr -d '()' || echo "")
SUBJECT=$(echo "$MSG" | head -1)

# TimeSpent 파싱
TIME=$(echo "$MSG" | grep -iE '^TimeSpent:' | cut -d: -f2 | xargs || echo "-")

# Category 파싱
CATEGORY=$(echo "$MSG" | grep -iE '^Category:' | cut -d: -f2 | xargs || echo "other")

# work_log.txt에 기록
LOGFILE="$HOME/work_log.txt"
echo "[$TIMESTAMP] [$HASH] $TYPE($SCOPE): $SUBJECT [${TIME}h] [${CATEGORY}]" >> "$LOGFILE"

# 디버그 (선택사항 - 제거 가능)
# echo "✅ Logged: $SUBJECT"
